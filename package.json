{
  "name": "@sugukuru-labs/mcp-houjin-bangou",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Japan's National Corporate Number (houjin-bangou) Web-API by NTA. MCP 7-primitive full activation + deterministic name normalization.",
  "license": "MIT",
  "author": "Sugukuru K.K. (Kagoshima) <engineering@sugukuru.co.jp>",
  "homepage": "https://github.com/sugukuru-labs/mcp-houjin-bangou#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sugukuru-labs/mcp-houjin-bangou.git"
  },
  "bugs": {
    "url": "https://github.com/sugukuru-labs/mcp-houjin-bangou/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "houjin-bangou",
    "corporate-number",
    "nta",
    "japan",
    "kyc",
    "claude",
    "anthropic",
    "cursor",
    "sugukuru"
  ],
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "bin": {
    "mcp-houjin-bangou": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.ja.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.11.1"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build",
    "health-check": "tsx scripts/api-id-keepalive.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
