# 国税庁 法人番号 Web-API Ver.4.0 アプリケーション ID
# NTA houjin-bangou Web-API application ID (required)
# ID Aplikasi Web-API Nomor Perusahaan NTA (wajib)
#
# 発行方法: https://www.invoice-kohyo.nta.go.jp/web-api/pre-reg/
# (適格請求書発行事業者公表サイト経由、第一編 §5.1)
# 同じ ID で適格請求書発行事業者 API も利用可能 (別添1 第2条第7号)
NTA_APPLICATION_ID=

# API エンドポイント (通常はデフォルト値のまま)
# 本番: https://api.houjin-bangou.nta.go.jp/4
# 検証環境: 国税庁から別途案内 (第一編 §7)
NTA_BASE_URL=https://api.houjin-bangou.nta.go.jp/4

# サーバーポート
PORT=3001

# ログレベル (fatal / error / warn / info / debug / trace)
LOG_LEVEL=info

# 実行環境 (development / test / production)
NODE_ENV=development

# レート制限 (国税庁 API への秒間リクエスト数、保守的に 1 RPS 推奨)
NTA_RATE_LIMIT_RPS=1

# API タイムアウト (ms)
NTA_TIMEOUT_MS=8000
